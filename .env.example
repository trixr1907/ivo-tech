# App runtime
NEXT_PUBLIC_SITE_URL=https://ivo-tech.com
NEXT_PUBLIC_APP_ENV=development
# Optional allow-list override for analytics hosts (comma-separated)
NEXT_PUBLIC_ANALYTICS_ALLOWED_HOSTS=

# Optional monitoring / security reporting
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_CSP_REPORT_URI=

# Optional contact delivery channels
# - Resend direct email (preferred for inbox delivery)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAILS=contact@ivo-tech.com,ivo@ivo-tech.com
# - Webhook fallback (e.g. Formspree/Discord/custom endpoint)
CONTACT_WEBHOOK_URL=

# Optional per-IP contact rate limits (defaults: 5 requests / 10 minutes)
CONTACT_RATE_LIMIT_PER_IP=
CONTACT_RATE_LIMIT_WINDOW_MINUTES=

# Optional persistent rate-limit store (Vercel KV / Upstash REST)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional server-side A/B ingestion throttle (defaults: 240 events / 10 minutes / IP)
AB_EVENT_RATE_LIMIT_PER_IP=
AB_EVENT_RATE_LIMIT_WINDOW_MINUTES=
# Optional host allow-list override for /api/analytics/ab-event (comma-separated)
AB_EVENT_ALLOWED_HOSTS=
# Optional decision gates for /internal/ab-report
# If unset, defaults depend on NEXT_PUBLIC_APP_ENV:
# - development: exposure=40, submits=4, delta_pp=0.75
# - staging: exposure=70, submits=7, delta_pp=0.9
# - production: exposure=120, submits=12, delta_pp=1.0
AB_REPORT_MIN_EXPOSURE_PER_VARIANT=
AB_REPORT_MIN_SUBMIT_EVENTS_TOTAL=
AB_REPORT_MIN_DELTA_PERCENTAGE_POINTS=
# Optional source-level decision gates for source attribution recommendations
# If unset, defaults depend on NEXT_PUBLIC_APP_ENV:
# - development: exposure=15, submits=2, delta_pp=0.5
# - staging: exposure=25, submits=3, delta_pp=0.75
# - production: exposure=40, submits=5, delta_pp=1.0
AB_REPORT_SOURCE_MIN_EXPOSURE_PER_VARIANT=
AB_REPORT_SOURCE_MIN_SUBMIT_EVENTS_TOTAL=
AB_REPORT_SOURCE_MIN_DELTA_PERCENTAGE_POINTS=

# Optional internal report access key for /internal/ab-report?key=...
INTERNAL_REPORT_TOKEN=

# Optional Cloudflare Turnstile protection for /api/contact
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
