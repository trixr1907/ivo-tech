# App runtime
NEXT_PUBLIC_SITE_URL=https://ivo-tech.com
NEXT_PUBLIC_APP_ENV=development
# Optional allow-list override for analytics hosts (comma-separated)
NEXT_PUBLIC_ANALYTICS_ALLOWED_HOSTS=
# Optional additional dev origins for Next.js (comma-separated, local only)
NEXT_ALLOWED_DEV_ORIGINS=
# Optional scheduler override for contact/thank-you CTA
NEXT_PUBLIC_SCHEDULER_URL=
# Optional hero experiment toggle and weights (default,outcome,speed)
NEXT_PUBLIC_HERO_EXPERIMENT_ENABLED=
NEXT_PUBLIC_HERO_EXPERIMENT_WEIGHTS=
# Optional analytics sink relay toggle (`true` routes events to /api/analytics)
NEXT_PUBLIC_ANALYTICS_SINK_ENABLED=
# Optional analytics sink provider (`none` | `posthog` | `plausible`)
ANALYTICS_SINK_PROVIDER=
# PostHog sink config
ANALYTICS_SINK_POSTHOG_PROJECT_KEY=
ANALYTICS_SINK_POSTHOG_HOST=https://us.i.posthog.com
# Plausible sink config
ANALYTICS_SINK_PLAUSIBLE_DOMAIN=
ANALYTICS_SINK_PLAUSIBLE_HOST=https://plausible.io
# Plausible Stats API key (for dashboard/alert ops scripts)
PLAUSIBLE_STATS_API_KEY=

# Optional monitoring / security reporting
NEXT_PUBLIC_SENTRY_DSN=
CSP_REPORT_URI=
NEXT_PUBLIC_CSP_REPORT_URI=

# Optional contact delivery channels
# - Resend direct email (preferred for inbox delivery)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAILS=contact@ivo-tech.com,ivo@ivo-tech.com
# - Webhook fallback (e.g. Formspree/Discord/custom endpoint)
CONTACT_WEBHOOK_URL=

# Optional per-IP contact rate limits (defaults: 5 requests / 10 minutes)
CONTACT_RATE_LIMIT_PER_IP=
CONTACT_RATE_LIMIT_WINDOW_MINUTES=

# Optional persistent rate-limit store (Vercel KV / Upstash REST)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional Cloudflare Turnstile protection for /api/contact
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
