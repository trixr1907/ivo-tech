{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KnowledgeDocument",
  "type": "object",
  "required": [
    "document_id",
    "source_id",
    "url",
    "version",
    "fetched_at",
    "language",
    "content_type",
    "sections"
  ],
  "properties": {
    "document_id": { "type": "string" },
    "source_id": { "type": "string" },
    "url": { "type": "string" },
    "canonical_url": { "type": "string" },
    "version": { "type": "string" },
    "fetched_at": { "type": "string", "format": "date-time" },
    "language": { "type": "string", "enum": ["de", "en", "mixed"] },
    "content_type": {
      "type": "string",
      "enum": ["homepage", "landing", "blog", "case_study", "faq", "other"]
    },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section_id", "section_type", "text"],
        "properties": {
          "section_id": { "type": "string" },
          "section_type": {
            "type": "string",
            "enum": [
              "navigation",
              "hero",
              "proof_bar",
              "services",
              "benefits",
              "trust",
              "testimonial",
              "insights",
              "process",
              "contact",
              "faq",
              "footer",
              "other"
            ]
          },
          "headline": { "type": "string" },
          "text": { "type": "string" },
          "ctas": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label"],
              "properties": {
                "label": { "type": "string" },
                "href": { "type": "string" },
                "intent": { "type": "string" }
              }
            }
          },
          "trust_signals": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
