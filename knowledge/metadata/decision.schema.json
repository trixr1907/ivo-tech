{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DesignDecision",
  "type": "object",
  "required": [
    "decision_id",
    "date",
    "status",
    "context",
    "decision",
    "rationale",
    "evidence_ids",
    "impact"
  ],
  "properties": {
    "decision_id": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "status": { "type": "string", "enum": ["proposed", "accepted", "deprecated"] },
    "context": { "type": "string" },
    "decision": { "type": "string" },
    "rationale": { "type": "string" },
    "evidence_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "alternatives_considered": {
      "type": "array",
      "items": { "type": "string" }
    },
    "impact": {
      "type": "object",
      "required": ["ux", "engineering", "copy"],
      "properties": {
        "ux": { "type": "string" },
        "engineering": { "type": "string" },
        "copy": { "type": "string" }
      }
    }
  }
}
