{
  "name": "ivo-tech",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "predev": "node scripts/copy-vendor.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/copy-vendor.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src scripts tests/e2e playwright.config.ts --cache --cache-location .cache/eslint --max-warnings 0",
    "lint:i18n": "node scripts/check-i18n-consistency.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:audit": "playwright test tests/e2e/site-audit.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "logo:build": "node scripts/build-logo-system.mjs",
    "brand:generate": "npm run logo:build && node scripts/optimize-images.mjs",
    "brand:generate:legacy": "python3 scripts/generate_logo_system.py",
    "verify:homepage:full": "npm run lint && npm run lint:i18n && npm run typecheck && npm run analytics:verify:map:strict && npm run test:unit && npm run test:e2e",
    "verify:release:local": "npm run build && npm run budget:bundle && npm run verify:homepage:full",
    "verify:site": "npm run build && npm run test:unit && npm run test:e2e:audit && npm run analytics:verify:map:strict",
    "optimize:images": "node scripts/optimize-images.mjs",
    "analyze": "ANALYZE=true next build",
    "budget:bundle": "node scripts/check-bundle-budgets.mjs",
    "budget:live": "node scripts/check-live-budgets.mjs",
    "analytics:verify:map": "node scripts/verify-analytics-event-map.mjs",
    "analytics:verify:map:strict": "node scripts/verify-analytics-event-map.mjs --strict-undocumented",
    "analytics:readiness": "node scripts/analytics-readiness.mjs",
    "analytics:readiness:strict": "node scripts/analytics-readiness.mjs --strict",
    "analytics:plausible:ops": "node scripts/analytics-plausible-ops.mjs",
    "analytics:plausible:ops:strict": "node scripts/analytics-plausible-ops.mjs --strict-alerts",
    "proof:readiness": "node scripts/proof-readiness.mjs",
    "proof:readiness:strict": "node scripts/proof-readiness.mjs --strict",
    "hero:experiment:plan": "node scripts/hero-experiment-plan.mjs",
    "analytics:live:readiness": "node scripts/analytics-live-readiness.mjs",
    "analytics:live:readiness:strict": "node scripts/analytics-live-readiness.mjs --strict",
    "hero:log:readiness": "node scripts/hero-log-readiness.mjs",
    "hero:log:readiness:strict": "node scripts/hero-log-readiness.mjs --strict",
    "hero:log:sync:plausible": "node scripts/hero-log-sync-plausible.mjs",
    "ops:readiness": "node scripts/ops-readiness.mjs",
    "ops:readiness:strict": "node scripts/ops-readiness.mjs --strict",
    "github:ops:readiness": "node scripts/github-ops-readiness.mjs",
    "github:ops:readiness:strict": "node scripts/github-ops-readiness.mjs --strict",
    "roadmap:sync": "node scripts/roadmap-sync.mjs",
    "masterplan:progress": "node scripts/masterplan-progress.mjs",
    "security:csp:summary": "node scripts/csp-report-summary.mjs",
    "security:scan": "npm audit --omit=dev --audit-level=high",
    "cf": "node scripts/cloudflare-cli.mjs",
    "cf:verify": "npm run cf -- verify-token",
    "cf:zones": "npm run cf -- zones:list",
    "cf:dns": "npm run cf -- dns:list",
    "cf:ensure:vercel": "npm run cf -- dns:ensure-vercel",
    "verify:live": "node scripts/verify-live-domains.mjs",
    "verify:live:full": "npm run verify:live && npm run budget:live",
    "verify:logos": "node scripts/verify-logo-assets.mjs",
    "cf:wrangler": "wrangler",
    "governance:apply": "node scripts/configure-github-governance.mjs",
    "setup:githooks": "git config core.hooksPath .githooks",
    "postinstall": "node scripts/copy-vendor.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "0.7.4",
    "framer-motion": "^12.34.3",
    "gray-matter": "^4.0.3",
    "jszip": "3.10.1",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "three": "0.128.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.39.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.3.1",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7",
    "autoprefixer": "^10.4.27",
    "eslint": "9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.9",
    "sharp": "^0.34.5",
    "start-server-and-test": "^2.1.3",
    "svgo": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.65.0"
  }
}
