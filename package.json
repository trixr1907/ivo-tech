{
  "name": "ivo-tech",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "predev": "node scripts/copy-vendor.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/copy-vendor.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src scripts --cache --cache-location .cache/eslint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "perf:lighthouse": "node scripts/run-lhci.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "analyze": "ANALYZE=true next build",
    "security:scan": "npm audit --audit-level=moderate",
    "cf": "node scripts/cloudflare-cli.mjs",
    "cf:verify": "npm run cf -- verify-token",
    "cf:zones": "npm run cf -- zones:list",
    "cf:dns": "npm run cf -- dns:list",
    "cf:ensure:vercel": "npm run cf -- dns:ensure-vercel",
    "verify:live": "node scripts/verify-live-domains.mjs",
    "cf:wrangler": "wrangler",
    "governance:apply": "node scripts/configure-github-governance.mjs",
    "setup:githooks": "git config core.hooksPath .githooks",
    "postinstall": "node scripts/copy-vendor.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@vercel/analytics": "^1.6.1",
    "fflate": "0.7.4",
    "jszip": "3.10.1",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "0.128.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.3.1",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7",
    "eslint": "9.39.0",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "sharp": "^0.34.5",
    "start-server-and-test": "^2.1.3",
    "typescript": "5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.65.0"
  }
}
